#!/usr/bin/env python3

import argparse
import os
import subprocess
import tomllib
import pathlib
import sys
import string

parser = argparse.ArgumentParser()
parser.add_argument("--inner", action="store_true")
args = parser.parse_args()

cwd = pathlib.Path.cwd()
secrets_dir = cwd / ".secrets"
secrets_vault_path = cwd / ".secrets.toml"
secrets_vault_decrypted_path = secrets_dir / "vault"
secrets_vault_decrypted_identity_path = secrets_dir / "identity"

if args.inner:
    if not secrets_dir.is_mount():
        raise RuntimeError(f"{secrets_dir} must be a tmpfs mountpoint")
    with open("/proc/mounts", "r") as mounts:
        ok = False
        for mount in mounts:
            mount_fields = mount.split()
            if pathlib.Path(mount_fields[1]) == secrets_dir:
                if mount_fields[2] == "tmpfs":
                    ok = True
                break
        if not ok:
            raise RuntimeError(f"{secrets_dir} must be a tmpfs mountpoint")

    subprocess.check_output(["ansible-vault", "decrypt", "--output", str(secrets_vault_decrypted_path), str(secrets_vault_path)])
    secrets_vault = None
    with secrets_vault_decrypted_path.open("rb") as vault_f:
        secrets_vault = tomllib.load(vault_f)
    secrets_vault_decrypted_path.unlink()

    ssh_keys = secrets_vault.get("ssh_keys", [])
    if type(ssh_keys) is not list:
        raise TypeError("ssh_keys must be an array of tables")
    for ssh_key in ssh_keys:
        if type(ssh_key) is not dict:
            raise TypeError("ssh_keys must be an array of tables")
        identity = ssh_key.get("identity")
        if identity is None or type(identity) is not str:
            raise KeyError("ssh_keys table must contain identity string")
        with secrets_vault_decrypted_identity_path.open("w") as file:
            file.write(identity)
        secrets_vault_decrypted_identity_path.chmod(0o600)
        subprocess.check_call(["ssh-add", str(secrets_vault_decrypted_identity_path)])
        secrets_vault_decrypted_identity_path.unlink()

    vars = secrets_vault.get("vars", {})
    if type(vars) is not dict:
        raise TypeError("vars must be a table")

    files = secrets_vault.get("files", [])
    if type(files) is not list:
        raise TypeError("files must be an array of tables")
    for file in files:
        if type(file) is not dict:
            raise TypeError("files must be an array of tables")
        file_name = file.get("name")
        if file_name is None or type(file_name) is not str:
            raise KeyError("files table must contain name string")
        file_content = file.get("content")
        if file_content is None or type(file_content) is not str:
            raise KeyError("files table must contain content string")
        file_content = string.Template(file_content).substitute(vars, cwd=cwd, secrets_dir=secrets_dir)
        file_path = secrets_dir / file_name
        with file_path.open("w") as file:
            file.write(file_content)
        file_path.chmod(0o600)

    env = secrets_vault.get("env", {})
    if type(env) is not dict:
        raise TypeError("env must be a table")
    for key, value in env.items():
        if type(key) is not str or type(value) is not str:
            raise TypeError("Keys and values in env must be strings")
        value = string.Template(value).substitute(vars, cwd=cwd, secrets_dir=secrets_dir)
        os.environ[key]=value

    shell = str(os.environ.get("SHELL"))
    os.execvp(shell, [shell])
else:
    os.execvp("bwrap", [
        "bwrap",
        "--bind", "/", "/",
        "--proc", "/proc",
        "--dev", "/dev",
        "--tmpfs", "/tmp",
        "--die-with-parent",
        "--tmpfs", str(secrets_dir),
        "ssh-agent",
        __file__,
        "--inner",
        *sys.argv[1:]
    ])
